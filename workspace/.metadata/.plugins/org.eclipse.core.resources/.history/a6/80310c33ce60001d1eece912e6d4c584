package com.comestic.dao.implement;

import java.util.List;

import com.comestic.dao.IUserDAO;
import com.comestic.model.UserModel;

public class UserDAO extends AbstractDAO<UserModel> implements IUserDAO {
	
	private Integer count;
	private List<Object> listInput;

	@Override
	public Integer handleLogin(UserModel userModel) {
		StringBuilder sql = new StringBuilder("select * from users where username=?");
		this.listInput.add(userModel.getUsername());
		this.count = count(sql.toString(), this.listInput);
	}

	

}
