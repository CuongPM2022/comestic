package com.comestic.dao.implement;

import java.util.List;

import com.comestic.dao.IUserDAO;
import com.comestic.dao.mapper.UserMapper;
import com.comestic.model.UserModel;

public class UserDAO extends AbstractDAO<UserModel> implements IUserDAO {
	
	List<Object> listInput;

	@Override
	public UserModel findOneByUserNameAndPassword(String username, String password) {
		StringBuilder sql = new StringBuilder("select u.id, username, u.name, i.name as image");
		sql.append(" from users u, image i where u.imageid = i.id and username=? and password=?");
		this.listInput.add(username);
		this.listInput.add(password);
		List<UserModel> listResult = query(sql.toString(), new UserMapper(), this.listInput);
		if(listResult != null && listResult.size() > 0) {
			return listResult.get(0);
		}
		return null;
	}

}
