package com.comestic.dao.implement;

import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.sql.Timestamp;
import java.text.MessageFormat;
import java.util.ArrayList;
import java.util.List;
import java.util.Map;
import java.util.Set;

import com.comestic.dao.IAbstractDAO;
import com.comestic.dao.mapper.IRowMapper;
import com.comestic.utils.Paging;

public class AbstractDAO<T> implements IAbstractDAO<T> {
	private String temp1, temp2;

	protected Connection getConnection() {
		Connection conn = null;
		PreparedStatement state = null;
		ResultSet resultSet = null;
		String url = "jdbc:mysql://localhost:3306/ecom_store";
		String username = "root";
		String password = "Cuong@12345";
		try {
			Class.forName("com.mysql.jdbc.Driver");
			conn = DriverManager.getConnection(url, username, password);
		} catch (ClassNotFoundException | SQLException e) {
			e.printStackTrace();
			conn = null;
		}
		return conn;
	}

	protected void closeConnection(Connection conn, PreparedStatement state, ResultSet resultSet) {
		try {
			if (this.resultSet != null) {
				this.resultSet.close();
			}

			if (this.state != null) {
				this.state.close();
			}

			if (this.conn != null) {
				this.conn.close();
			}
		} catch (SQLException e) {
			e.printStackTrace();
		}
	}

	@Override
	public List<T> query(String sql, IRowMapper<T> rowMapper, Object... parameters) {
		this.conn = getConnection();
		List<T> list = null;
		if (this.conn != null) {
			list = new ArrayList<T>();
			try {
				this.state = this.conn.prepareStatement(sql);
				setParameter(this.state, parameters);
				this.resultSet = this.state.executeQuery();
				if (this.resultSet != null) {
					while (resultSet.next()) {
						list.add(rowMapper.mapRow(resultSet));
					}
				}
			} catch (SQLException e) {
				e.printStackTrace();
				list = null;
			} finally {
				closeConnection();
			}
		}
		return list;
	}

	@Override
	public Integer count(String sql, Object... paremeters) {
		Integer count = 0;
		this.conn = getConnection();
		if (this.conn != null) {
			try {
				this.state = this.conn.prepareStatement(sql);
				setParameter(state, paremeters);
				this.resultSet = this.state.executeQuery();
				if (this.resultSet != null) {
					if (this.resultSet.next()) {
						count = this.resultSet.getInt(1);
					}
				}
			} catch (SQLException e) {
				count = 0;
				e.printStackTrace();
			} finally {
				closeConnection();
			}
		}
		return count;
	}

	@Override
	public Object getRecord(String sql, Object... paremeters) {
		Object result = null;
		this.conn = getConnection();
		if (this.conn != null) {
			try {
				this.state = this.conn.prepareStatement(sql);
				setParameter(state, paremeters);
				this.resultSet = this.state.executeQuery();
				if (this.resultSet != null) {
					if (this.resultSet.next()) {
						result = this.resultSet.getObject(1);
					}
				}
			} catch (SQLException e) {
				result = null;
				e.printStackTrace();
			} finally {
				closeConnection();
			}

		}
		return result;
	}

	@Override
	public Long insert(String sql, Object... paremeters) {
		Long id = null;
		this.conn = getConnection();
		if (this.conn != null) {
			try {
				this.conn.setAutoCommit(false);
				this.state = this.conn.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS);
				setParameter(state, paremeters);
				this.state.executeUpdate();
				this.resultSet = this.state.getGeneratedKeys();
				if (this.resultSet.next()) {
					id = resultSet.getLong(1);
				}
				this.conn.commit();
			} catch (SQLException e) {
				if (this.conn != null) {
					try {
						this.conn.rollback();
					} catch (SQLException e1) {
						e1.printStackTrace();
					}
				}
				id = null;
				e.printStackTrace();
			} finally {
				closeConnection();
			}
		}
		return id;
	}

	@Override
	public void update(String sql, Object... paremeters) {
		this.conn = getConnection();
		if (this.conn != null) {
			try {
				this.conn.setAutoCommit(false);
				this.state = this.conn.prepareStatement(sql);
				setParameter(state, paremeters);
				this.state.executeUpdate();
				this.conn.commit();
			} catch (SQLException e) {
				e.printStackTrace();
				if (this.conn != null) {
					try {
						this.conn.rollback();
					} catch (SQLException e1) {
						e1.printStackTrace();
					}
				}
			} finally {
				closeConnection();
			}
		}

	}

	protected void setPaging(StringBuilder sql, Paging paging) {
		if (paging != null) {
			setFilter(sql, paging);

			if (paging.getSortName() != null) {
				sql.append(MessageFormat.format(" order by {0} {1}", paging.getSortName(), paging.getSortBy()));
			}

			if (paging.getOffset() != null) {
				sql.append(MessageFormat.format(" limit {0},{1}", paging.getOffset(), paging.getMaxItem()));
			}
		}
	}

	protected void setFilter(StringBuilder sql, Paging paging) {
		if (paging != null) {
			if (paging.getFilter() != null) {
				if (!sql.toString().contains(" where")) {
					sql.append(" where 1");
				}

				Map<String, Object> temp = paging.getFilter();
				Set<String> set = temp.keySet();
				for (String key : set) {
					if (key.equals("manufactureid") || key.equals("categoryid") || key.equals("stateid")) {
						sql.append(MessageFormat.format(" and {0}={1}", key, temp.get(key).toString()));
					} else if (key.equals("pricemin")) {
						sql.append(MessageFormat.format(" and price>={0}", temp.get(key).toString()));
					} else if (key.equals("pricemax")) {
						sql.append(MessageFormat.format(" and price<={0}", temp.get(key).toString()));
					} else if (key.equals("sale")) {
						sql.append(" and percentdes!=0");
					}
				}
			}
		}
	}
	
	protected void setPagingHasFilterDate(StringBuilder sql, Paging paging, List<Object> listInput) {
		if(paging != null) {
			setPaging(sql, paging);
			if(paging.getFilter() != null) {
				setFilter(sql, paging);
				Map<String, Object> temp = paging.getFilter();
				Set<String> set = temp.keySet();
				for (String key : set) {
					if(key.equals("minday")) {
						sql.append(" and date>=?");
						this.temp1 = temp.get(key).toString();
						listInput.add(this.temp1);
					}
					else if(key.equals("maxday")) {
						// mysql not get day equals value
						this.temp2 = temp.get(key).toString();
						if(!this.temp1.equals(this.temp2)) {
							sql.append(" and date<=?");
							listInput.add(this.temp2);
						}
					}
				}
			}
		}
		
	}

	private void setParameter(PreparedStatement state, Object... parameters) {
		if (parameters.length != 0) {
			@SuppressWarnings("unchecked")
			List<Object> list = (List<Object>) parameters[0];
			int length = list.size();
			try {
				for (int i = 0; i < length; i++) {
					if (list.get(i) instanceof Integer) {
						state.setInt(i + 1, (Integer) list.get(i));
					} else if (list.get(i) instanceof Long) {
						state.setLong(i + 1, (Long) list.get(i));
					} else if (list.get(i) instanceof Double) {
						state.setDouble(i + 1, (Double) list.get(i));
					} else if (list.get(i) instanceof String) {
						state.setString(i + 1, (String) list.get(i));
					} else if (list.get(i) instanceof Timestamp) {
						state.setTimestamp(i + 1, (Timestamp) list.get(i));
					}
				}
			} catch (SQLException e) {
				e.printStackTrace();
			}
		}

	}

}
